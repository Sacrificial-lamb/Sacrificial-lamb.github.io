<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>❤️ 给最爱的你</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      background: #ffe6f0;
      font-family: "Microsoft YaHei", sans-serif;
      overflow: hidden;
    }
    .heart {
      position: relative;
      width: 120px;
      height: 100px;
      animation: heartbeat 1.2s infinite;
    }
    .heart:before,
    .heart:after {
      position: absolute;
      content: "";
      top: 0;
      width: 120px;
      height: 100px;
      background: #ff4d7a;
      border-radius: 50%;
    }
    .heart:before {
      left: -60px;
      background: linear-gradient(135deg, #ff6b8b, #ff4d7a);
    }
    .heart:after {
      left: 0;
      background: linear-gradient(135deg, #ff4d7a, #e03666);
    }
    .text {
      text-align: center;
      margin-top: 30px;
      color: #d4235d;
      font-size: 24px;
      font-weight: bold;
      text-shadow: 0 1px 2px rgba(0,0,0,0.1);
    }
    @keyframes heartbeat {
      0% { transform: scale(1); }
      14% { transform: scale(1.15); }
      28% { transform: scale(1); }
      42% { transform: scale(1.15); }
      70% { transform: scale(1); }
    }
  </style>
</head>
<body>
  <div>
    <div class="heart"></div>
    <div class="text">Love You, 宝贝！❤️</div>
  </div>
</body>
</html>
